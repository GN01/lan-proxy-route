#!/bin/sh /etc/rc.common

START=95
STOP=05
USE_PROCD=1

SERVICE=/usr/share/lan-proxy-route/lan-proxy-route.sh
EXTRA_COMMANDS="diagnose trace"
EXTRA_HELP="        diagnose        Run service diagnostics
        trace           Validate config and print rendered commands"

start_service() {
	"$SERVICE" apply
}

reload_service() {
	"$SERVICE" cleanup
	"$SERVICE" apply
}

stop_service() {
	"$SERVICE" cleanup
}

diagnose() {
	"$SERVICE" diagnose
}

trace() {
	"$SERVICE" validate
	LPR_DRY_RUN=1 "$SERVICE" render
}

status_service() {
	"$SERVICE" diagnose
}
