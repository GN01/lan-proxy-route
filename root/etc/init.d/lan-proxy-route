#!/bin/sh /etc/rc.common

START=95
STOP=05
USE_PROCD=1

SERVICE=/usr/share/lan-proxy-route/lan-proxy-route.sh
EXTRA_COMMANDS="diagnose"
EXTRA_HELP="        diagnose        Run service diagnostics"

start_service() {
	"$SERVICE" apply
	/etc/init.d/dnsmasq reload >/dev/null 2>&1 || true
	/etc/init.d/firewall reload >/dev/null 2>&1 || true
}

reload_service() {
	"$SERVICE" cleanup
	"$SERVICE" apply
	/etc/init.d/dnsmasq reload >/dev/null 2>&1 || true
	/etc/init.d/firewall reload >/dev/null 2>&1 || true
}

stop_service() {
	"$SERVICE" cleanup
}

diagnose() {
	"$SERVICE" diagnose
}

status_service() {
	"$SERVICE" diagnose
}
