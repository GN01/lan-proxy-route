#!/bin/sh

SERVICE="${LPR_RPCD_SERVICE:-/usr/share/lan-proxy-route/lan-proxy-route.sh}"

lpr_rpcd_reload() {
	if ! "$SERVICE" cleanup >/dev/null 2>&1; then
		printf '{"ok":false,"error":"cleanup failed"}\n'
		return 1
	fi
	if ! "$SERVICE" apply >/dev/null 2>&1; then
		printf '{"ok":false,"error":"apply failed"}\n'
		return 1
	fi
	printf '{"ok":true}\n'
}

lpr_rpcd_test_route() {
	dst="${1:-8.8.8.8}"
	"$SERVICE" test-route "$dst"
}

case "${1:-list}" in
	list)
		cat <<'EOF'
{
  "status": {},
  "reload": {},
  "test_route": {
    "src": "String",
    "dst": "String"
  }
}
EOF
		;;
	call)
		method="$2"
		case "$method" in
			status) "$SERVICE" diagnose ;;
			reload) lpr_rpcd_reload ;;
			test_route) lpr_rpcd_test_route "${3:-8.8.8.8}" ;;
			*) printf '{"error":"unknown method"}\n'; exit 1 ;;
		esac
		;;
	*) printf '{"error":"usage"}\n'; exit 1 ;;
esac
