{
  "luci-app-lan-proxy-route": {
    "description": "Grant access to LAN Proxy Route",
    "read": {
      "uci": [ "lan_proxy_route" ],
      "ubus": {
        "lan-proxy-route": [ "status", "logs", "test_route", "check_chnroute" ]
      }
    },
    "write": {
      "uci": [ "lan_proxy_route" ],
      "ubus": {
        "lan-proxy-route": [ "reload", "update_chnroute" ]
      }
    }
  }
}
